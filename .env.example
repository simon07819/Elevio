# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site URLs ──
NEXT_PUBLIC_SITE_URL=https://elevio-seven.vercel.app
NEXT_PUBLIC_APP_URL=https://elevio-seven.vercel.app

# ── Superadmin ──
SUPERADMIN_EMAIL=your-admin@example.com

# ── PostHog Analytics (optional) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry Error Tracking (optional) ──
NEXT_PUBLIC_SENTRY_DSN=

# ── Debug ──
NEXT_PUBLIC_DEBUG_SYNC=false

# ── Stripe (web billing only — NEVER used on iOS) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── RevenueCat (iOS IAP — REQUIRED for App Store) ──
# Get your API key from RevenueCat Dashboard -> Project Settings -> API Keys
# Use the PUBLIC Apple API key (starts with "appl_")
NEXT_PUBLIC_REVENUECAT_API_KEY=
# Webhook auth token — set in RevenueCat Dashboard -> Webhooks
# This is a custom secret you choose; RevenueCat sends it as Bearer token
REVENUECAT_WEBHOOK_AUTH_TOKEN=

# ── Capacitor iOS ──
# The URL the Capacitor WebView loads (your deployed Next.js app)
CAPACITOR_SERVER_URL=https://elevio-seven.vercel.app

# ── Cron (Vercel) ──
CRON_SECRET=

# ── Apple Sign-In (iOS) ──
# On iOS Capacitor: native plugin uses App Bundle ID automatically
# On web: Apple JS SDK requires a Service ID
NEXT_PUBLIC_APPLE_WEB_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=

# ── Email / SMTP ──
# Used for support ticket notifications and future email features.
# Supabase Auth emails (signup confirmation, password reset) use
# Supabase's built-in SMTP unless you configure Custom SMTP in
# the Supabase Dashboard → Authentication → SMTP Settings.
SMTP_HOST=box201.effetmonstre.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@elevioapp.ca
SMTP_PASSWORD=
SMTP_FROM=Elevio <info@elevioapp.ca>
SUPPORT_EMAIL=info@elevioapp.ca
