{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["e2e/**/*.ts", "e2e-live/**/*.ts", "playwright.config.ts", "playwright.config.live.ts"],
  "exclude": ["node_modules"]
}
