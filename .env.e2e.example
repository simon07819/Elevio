# Live E2E test environment variables.
# Copy to .env.e2e and fill in real values.
# NEVER commit .env.e2e with real credentials.

# Target URL (Vercel preview or production)
E2E_BASE_URL=https://your-app.vercel.app

# Admin credentials (existing account)
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=changeme

# Operator credentials (existing account)
E2E_OPERATOR1_EMAIL=operator1@example.com
E2E_OPERATOR2_EMAIL=operator2@example.com
E2E_OPERATOR_PASSWORD=changeme

# Test project name (will be created then deleted)
E2E_TEST_PROJECT_NAME=E2E Test Auto
