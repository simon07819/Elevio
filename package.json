{
  "name": "elevio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsc -p tsconfig.test.json && node --test .test-build/tests/*.test.js",
    "test:e2e:buttons:live": "npx playwright test --project=button-audit",
    "test:e2e:chaos:live": "npx playwright test --project=chaos",
    "test:e2e:50:live": "npx playwright test --project=50-scenarios",
    "test:e2e:stress-crossing:live": "npx playwright test --project=stress-crossing",
    "test:e2e:pickup-qr:live": "npx playwright test --project=pickup-qr-return",
    "test:e2e:operator-real-flow:live": "npx playwright test --project=operator-real-flow",
    "test:e2e:full-live-regression": "npx playwright test --project=full-live-regression",
    "test:e2e:live": "npx playwright test",
    "typecheck": "tsc --noEmit",
    "cleanup:requests": "curl -s -X POST \"$NEXT_PUBLIC_SUPABASE_URL/rest/v1/rpc/cleanup_terminal_requests\" -H \"apikey: $SUPABASE_SERVICE_ROLE_KEY\" -H \"Authorization: Bearer $SUPABASE_SERVICE_ROLE_KEY\" -H \"Content-Type: application/json\" -d '{}' | jq ."
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@revenuecat/purchases-capacitor": "^13.0.1",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "clsx": "latest",
    "jsqr": "^1.4.0",
    "lucide-react": "latest",
    "next": "latest",
    "posthog-js": "^1.372.8",
    "qrcode": "latest",
    "react": "latest",
    "react-dom": "latest",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "latest",
    "@types/qrcode": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
